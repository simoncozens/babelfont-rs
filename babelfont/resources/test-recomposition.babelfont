  "note": "Cyrillic color coding\n\n1. Cyan – components done by Trifon & Botio\n2. Light Green – designed by Ksenya unchanged\n3. Orange – changed by Trifon & Botio\n4. Purple – improved after review\n5. No color – sill to be done after next assignment from Dave and Simon\n\n\n",
  "date": "2025-02-06T10:00:06Z",
  "names": {
    "copyright": {
      "dflt": "Copyright 2022 The Noto Project Authors (https://github.com/notofonts/latin-greek-cyrillic)"
    },
    "family_name": {
      "dflt": "Noto Serif"
    },
    "trademark": {
      "dflt": "Noto is a trademark of Google LLC."
    },
    "manufacturer": {
      "dflt": "Monotype Imaging Inc."
    },
    "designer": {
      "dflt": "Monotype Design Team"
    },
    "description": {
      "dflt": "Designed by Monotype design team."
    },
    "manufacturer_url": {
      "dflt": "http://www.google.com/get/noto/"
    },
    "designer_url": {
      "dflt": "http://www.monotype.com/studio"
    },
    "license": {
      "dflt": "This Font Software is licensed under the SIL Open Font License, Version 1.1. This license is available with a FAQ at: https://scripts.sil.org/OFL"
    },
    "license_url": {
      "dflt": "https://scripts.sil.org/OFL"
    },
    "postscript_cid_name": {
      "dflt": "NotoSerif"
    }
  },
  "custom_ot_values": {
    "os2_vendor_id": "GOOG",
    "os2_fs_selection": 128
  },
  "features": {
    "classes": {},
    "prefixes": {
      "anonymous": {
        "code": "@Uppercase = [A O Aacute Oacute Otilde Otildeacute];\n# Prefix: Languagesystems\nlanguagesystem DFLT dflt;\nlanguagesystem latn dflt;\nlanguagesystem grek dflt;\nlanguagesystem grek IPPH;\nlanguagesystem grek APPH;\nlanguagesystem cyrl dflt;\nlanguagesystem latn CAT;\nlanguagesystem latn MOL;\nlanguagesystem latn ROM;\nlanguagesystem latn MAH;\nlanguagesystem latn NAV;\nlanguagesystem latn IPPH;\nlanguagesystem latn APPH;\nlanguagesystem cyrl SRB;\nlanguagesystem cyrl MKD;\nfeature ccmp {\n# zero.slash alternate\n        lookup latnSoftDot {\n        @CombiningTopAccents = [acutecomb tildecomb];\n        # Removed glyph class SoftDotted due to no glyphs remaining\n        # Removed glyph class SoftDottedDotless due to no glyphs remaining\n        lookupflag UseMarkFilteringSet @CombiningTopAccents;\n    } latnSoftDot;\n    # Removed lookup latnLigatures due to no statements remaining\n    script latn;\n    language dflt;\n    lookup latnSoftDot;\n    # Removed lookup reference to latnLigatures due to lookup being dropped\n    language CAT;\n    lookup latnSoftDot;\n    # Removed lookup reference to latnLigatures due to lookup being dropped\n    language MAH;\n    lookup latnSoftDot;\n    # Removed lookup reference to latnLigatures due to lookup being dropped\n    language MOL;\n    lookup latnSoftDot;\n    # Removed lookup reference to latnLigatures due to lookup being dropped\n    language NAV;\n    lookup latnSoftDot;\n    # Removed lookup reference to latnLigatures due to lookup being dropped\n    language ROM;\n    lookup latnSoftDot;\n    # Removed lookup reference to latnLigatures due to lookup being dropped\n    script grek;\n    # Greek\n    # sub alpha macroncomb commaabovecomb gravecomb by alpha_macroncomb_commaabovecomb_gravecomb;\n    # sub alpha macroncomb commaabovecomb acutecomb by alpha_macroncomb_commaabovecomb_acutecomb;\n    # sub alpha macroncomb commareversedabovecomb gravecomb by alpha_macroncomb_commareversedabovecomb_gravecomb;\n    # sub alpha macroncomb commareversedabovecomb acutecomb by alpha_macroncomb_commareversedabovecomb_acutecomb;\n    # sub alpha brevecomb commaabovecomb gravecomb by alpha_brevecomb_commaabovecomb_gravecomb;\n    # sub alpha brevecomb commaabovecomb acutecomb by alpha_brevecomb_commaabovecomb_acutecomb;\n    # sub alpha brevecomb commareversedabovecomb gravecomb by alpha_brevecomb_commareversedabovecomb_gravecomb;\n    # sub alpha brevecomb commareversedabovecomb acutecomb by alpha_brevecomb_commareversedabovecomb_acutecomb;\n    # sub iota macroncomb commaabovecomb gravecomb by iota_macroncomb_commaabovecomb_gravecomb;\n    # sub iota macroncomb commaabovecomb acutecomb by iota_macroncomb_commaabovecomb_acutecomb;\n    # sub iota macroncomb commareversedabovecomb gravecomb by iota_macroncomb_commareversedabovecomb_gravecomb;\n    # sub iota macroncomb commareversedabovecomb acutecomb by iota_macroncomb_commareversedabovecomb_acutecomb;\n    # sub iota brevecomb commaabovecomb gravecomb by iota_brevecomb_commaabovecomb_gravecomb;\n    # sub iota brevecomb commaabovecomb acutecomb by iota_brevecomb_commaabovecomb_acutecomb;\n    # sub iota brevecomb commareversedabovecomb gravecomb by iota_brevecomb_commareversedabovecomb_gravecomb;\n    # sub iota brevecomb commareversedabovecomb acutecomb by iota_brevecomb_commareversedabovecomb_acutecomb;\n    # sub upsilon macroncomb commaabovecomb gravecomb by upsilon_macroncomb_commaabovecomb_gravecomb;\n    # sub upsilon macroncomb commaabovecomb acutecomb by upsilon_macroncomb_commaabovecomb_acutecomb;\n    # sub upsilon macroncomb commareversedabovecomb gravecomb by upsilon_macroncomb_commareversedabovecomb_gravecomb;\n    # sub upsilon macroncomb commareversedabovecomb acutecomb by upsilon_macroncomb_commareversedabovecomb_acutecomb;\n    # sub upsilon brevecomb commaabovecomb gravecomb by upsilon_brevecomb_commaabovecomb_gravecomb;\n    # sub upsilon brevecomb commaabovecomb acutecomb by upsilon_brevecomb_commaabovecomb_acutecomb;\n    # sub upsilon brevecomb commareversedabovecomb gravecomb by upsilon_brevecomb_commareversedabovecomb_gravecomb;\n    # sub upsilon brevecomb commareversedabovecomb acutecomb by upsilon_brevecomb_commareversedabovecomb_acutecomb;\n    # sub iota dieresiscomb macroncomb gravecomb by iota_dieresiscomb_macroncomb_gravecomb;\n    # sub iota dieresiscomb macroncomb acutecomb by iota_dieresiscomb_macroncomb_acutecomb;\n    # sub iota dieresiscomb brevecomb gravecomb by iota_dieresiscomb_brevecomb_gravecomb;\n    # sub iota dieresiscomb brevecomb acutecomb by iota_dieresiscomb_brevecomb_acutecomb;\n    # sub upsilon dieresiscomb macroncomb gravecomb by upsilon_dieresiscomb_macroncomb_gravecomb;\n    # sub upsilon dieresiscomb macroncomb acutecomb by upsilon_dieresiscomb_macroncomb_acutecomb;\n    # sub upsilon dieresiscomb brevecomb gravecomb by upsilon_dieresiscomb_brevecomb_gravecomb;\n    # sub upsilon dieresiscomb brevecomb acutecomb by upsilon_dieresiscomb_brevecomb_acutecomb;\n    # script cyrl;\n    #sub afii10103 by afii10103dotless;\n    #sub afii10105 by afii10105dotless;\n} ccmp;\n# Removed feature aalt due to no statements remaining\n# Removed feature locl due to no statements remaining\n# Removed feature mgrk due to no statements remaining\n# Removed feature subs due to no statements remaining\n# Removed feature sinf due to no statements remaining\n# Removed feature sups due to no statements remaining\n# Removed feature numr due to no statements remaining\n# Removed feature dnom due to no statements remaining\n# Removed feature frac due to no statements remaining\n# Removed feature ordn due to no statements remaining\n# Removed feature lnum due to no statements remaining\n# Removed feature pnum due to no statements remaining\n# Removed feature tnum due to no statements remaining\n# Removed feature onum due to no statements remaining\n# Removed feature c2sc due to no statements remaining\n# Removed feature smcp due to no statements remaining\n# Removed feature case due to no statements remaining\n# Removed feature liga due to no statements remaining\n# Removed feature rtlm due to no statements remaining\n# Removed feature zero due to no statements remaining\n# Removed feature ss03 due to no statements remaining\n# Removed feature ss06 due to no statements remaining\n# Removed feature ss07 due to no statements remaining\n"
      }
    },
