    "openTypeFeatures":[
      {
        "feature":"###\n# OpenType Layout feature definitions\n# Format: Adobe FDK for OpenType (AFDKO) version 2.5\n# Generated on: 2026-6-3 11:15\n# Generated by: FontLab 8.0.0\n# Font PostScript name: Vazir-Bold\n# Font copyright: Copyright (c) 2003 by Bitstream, Inc. All Rights Reserved.DejaVu changes are in public domainChanges by Saber Rastikerdar are in public domain.Non-Arabic(Latin) glyphs and data in extended version are imported from Roboto font under the Apache License, Version 2.0.\n#\n# Totals:\n# Languagesystems: 33\n# GSUB lookups: 9\n# GSUB features: 5 (fina, init, liga, medi, rlig)\n# GPOS lookups: 8\n# GPOS features: 3 (kern, mark, mkmk)\n\n#\n# Languagesystem definitions\n#\n\nlanguagesystem DFLT dflt; # Default default\nlanguagesystem latn dflt; # Latin default\nlanguagesystem latn ISM ; # Latin Inari Sami\nlanguagesystem latn KSM ; # Latin Kildin Sami\nlanguagesystem latn LSM ; # Latin Lule Sami\nlanguagesystem latn MOL ; # Latin Moldavian\nlanguagesystem latn NSM ; # Latin Sami Northern\nlanguagesystem latn ROM ; # Latin Romanian\nlanguagesystem latn SKS ; # Latin Skolt Sami\nlanguagesystem latn SSM ; # Latin Sami Southern\nlanguagesystem arab dflt; # Arabic default\nlanguagesystem arab KUR ; # Arabic Kurdish\nlanguagesystem arab SND ; # Arabic Sindhi\nlanguagesystem arab URD ; # Arabic Urdu\nlanguagesystem armn dflt; # Armenian default\nlanguagesystem brai dflt; # Braille default\nlanguagesystem cans dflt; # Canadian Syllabics default\nlanguagesystem cher dflt; # Cherokee default\nlanguagesystem cyrl dflt; # Cyrillic default\nlanguagesystem cyrl MKD ; # Cyrillic Macedonian\nlanguagesystem cyrl SRB ; # Cyrillic Serbian\nlanguagesystem geor dflt; # Georgian default\nlanguagesystem grek dflt; # Greek default\nlanguagesystem hani dflt; # CJK Ideographic default\nlanguagesystem hebr dflt; # Hebrew default\nlanguagesystem kana dflt; # Hiragana default\nlanguagesystem lao  dflt; # Lao default\nlanguagesystem math dflt; # Mathematical Alphanumeric Symbols default\nlanguagesystem nko  dflt; # N'Ko default\nlanguagesystem ogam dflt; # Ogham default\nlanguagesystem runr dflt; # Runic default\nlanguagesystem tfng dflt; # Tifinagh default\nlanguagesystem thai dflt; # Thai default\n\n#\n# Lookup definitions\n#\n\n\n#\n# Feature definitions\n#\n"
      },
      {
        "name":"fina",
        "feature":"feature fina {\n# GSUB feature: Terminal Forms\n# Lookups: 1\n\n  script arab; # Arabic\n\n  lookup fina_arab {\n  # GSUB lookup 1, type 11 (Single)\n    lookupflag IgnoreMarks RightToLeft;\n    sub @fina by @fina2;\n  } fina_arab;\n\n    language SND ; # Sindhi\n    language URD ; # Urdu\n    language KUR ; # Kurdish\n\n} fina;\n"
      },
      {
        "name":"medi",
        "feature":"feature medi {\n# GSUB feature: Medial Forms\n# Lookups: 1\n\n  script arab; # Arabic\n\n  lookup medi_arab {\n  # GSUB lookup 2, type 11 (Single)\n    lookupflag IgnoreMarks RightToLeft;\n    sub @init_medi by @medi;\n  } medi_arab;\n\n    language SND ; # Sindhi\n    language URD ; # Urdu\n    language KUR ; # Kurdish\n\n} medi;\n"
      },
