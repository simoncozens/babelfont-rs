features = (
{
code = "# GSUB feature: Terminal Forms
# Lookups: 1

  script arab; # Arabic

  lookup fina_arab {
  # GSUB lookup 1, type 11 (Single)
    lookupflag IgnoreMarks RightToLeft;
    sub @fina by @fina2;
  } fina_arab;

    language SND ; # Sindhi
    language URD ; # Urdu
    language KUR ; # Kurdish";
