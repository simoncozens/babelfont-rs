#
# Totals:
# Languagesystems: 33
# GSUB lookups: 9
# GSUB features: 5 (fina, init, liga, medi, rlig)
# GPOS lookups: 8
# GPOS features: 3 (kern, mark, mkmk)

#
# Languagesystem definitions
#

languagesystem DFLT dflt; # Default default
languagesystem latn dflt; # Latin default
languagesystem latn ISM ; # Latin Inari Sami
languagesystem latn KSM ; # Latin Kildin Sami
languagesystem latn LSM ; # Latin Lule Sami
languagesystem latn MOL ; # Latin Moldavian
languagesystem latn NSM ; # Latin Sami Northern
languagesystem latn ROM ; # Latin Romanian
languagesystem latn SKS ; # Latin Skolt Sami
languagesystem latn SSM ; # Latin Sami Southern
languagesystem arab dflt; # Arabic default
languagesystem arab KUR ; # Arabic Kurdish
languagesystem arab SND ; # Arabic Sindhi
languagesystem arab URD ; # Arabic Urdu
languagesystem armn dflt; # Armenian default
languagesystem brai dflt; # Braille default
languagesystem cans dflt; # Canadian Syllabics default
languagesystem cher dflt; # Cherokee default
languagesystem cyrl dflt; # Cyrillic default
languagesystem cyrl MKD ; # Cyrillic Macedonian
languagesystem cyrl SRB ; # Cyrillic Serbian
languagesystem geor dflt; # Georgian default
languagesystem grek dflt; # Greek default
languagesystem hani dflt; # CJK Ideographic default
languagesystem hebr dflt; # Hebrew default
languagesystem kana dflt; # Hiragana default
languagesystem lao  dflt; # Lao default
languagesystem math dflt; # Mathematical Alphanumeric Symbols default
languagesystem nko  dflt; # N'Ko default
languagesystem ogam dflt; # Ogham default
languagesystem runr dflt; # Runic default
languagesystem tfng dflt; # Tifinagh default
languagesystem thai dflt; # Thai default

#
# Lookup definitions
#


#
# Feature definitions
#
";
tag = Languagesystems;
}
