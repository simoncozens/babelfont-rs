markClass acute <anchor 350 0> @TOP_MARKS;
markClass grave <anchor 200 150> @TOP_MARKS;
markClass dotbelowcomb <anchor 200 -200> @BOTTOM_MARKS;

lookup gsub1 { 
    sub a by b;
} gsub1;
lookup gsub2 { 
    sub a by b c;
} gsub2;
lookup gsub3 { 
    sub a from [b c d e f];
} gsub3;
lookup gsub4 { 
    sub b c by a;
} gsub4;
lookup gsub5 {
    sub [a one]' lookup gsub1 b' [c two]' lookup gsub2;
} gsub5;
lookup gsub6_f1 {
    sub one two three a' lookup gsub1 b' c' lookup gsub2 x y z;
} gsub6_f1;

lookup gpos4 {
    pos base A <anchor 150 100> mark @TOP_MARKS <anchor -200 -200> mark @BOTTOM_MARKS;

} gpos4;
